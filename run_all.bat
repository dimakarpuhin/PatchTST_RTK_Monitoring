@echo off
echo ============================================================
echo   ЗАПУСК ВСЕХ КОМПОНЕНТОВ СИСТЕМЫ
echo   Нейросетевой модуль классификации неопределённостей РТК
echo ============================================================
echo.

:: Проверка наличия Python
where python >nul 2>nul
if %errorlevel% neq 0 (
    echo [ОШИБКА] Python не найден.
    echo Установите Python 3.9 или выше.
    echo.
    pause
    exit /b 1
)

echo [ИНФО] Запуск сервера в новом окне...
start "PatchTST Сервер" cmd /c run_server.bat

:: Ожидание запуска сервера
echo [ИНФО] Ожидание запуска сервера (5 секунд)...
timeout /t 5 /nobreak >nul

echo [ИНФО] Запуск клиента оператора в новом окне...
start "PatchTST Клиент" cmd /c run_client.bat

echo [ИНФО] Запуск панели администратора в новом окне...
start "PatchTST Администратор" cmd /c run_admin.bat

echo.
echo ============================================================
echo   ВСЕ КОМПОНЕНТЫ ЗАПУЩЕНЫ
echo ============================================================
echo.
echo Закройте окна приложений для завершения работы.
echo.

pause